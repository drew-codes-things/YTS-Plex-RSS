# Plex connection
PLEX_USER_TOKEN=your_plex_token_here
PLEX_SERVER_NAME=My_Plex_Server
LIBRARY_NAME=Movies

# Scan behaviour
# MIN_YEAR: Only fetch YTS movies from this year onwards (fast mode).
# Set to 0 to scan the entire YTS catalogue (slow, resumes across runs).
MIN_YEAR=0

# SLEEP_SECONDS: Delay between YTS API pages to avoid rate-limiting.
SLEEP_SECONDS=1.2

# USE_MAL_FILTER: Set to true to skip movies that appear on MyAnimeList
# (i.e. anime films). Requires internet access to api.jikan.moe.
USE_MAL_FILTER=false

# QUALITY: Torrent quality to search for and match against.
# Allowed values: 720p | 1080p | 2160p
QUALITY=1080p
